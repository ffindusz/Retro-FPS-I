[gd_scene load_steps=3 format=3]

; Decorative "remains" prop: a compact pile of rubble standing in for a fallen
; body. Deliberately NOT a skeleton model — every skeleton_*.glb is used by a
; live enemy (skeleton_rogue = enemy_rogue, etc.), so reusing one as scenery
; made inert decoration indistinguishable from an attacker (worst in level_05,
; which spawns the rogue enemy). rubble_half is scaled to ~half so it reads as
; scattered remains and still fits tight spots like the level_05 cells.

[ext_resource type="PackedScene" path="res://assets/models/rubble_half/rubble_half.glb" id="1_model"]

[sub_resource type="BoxShape3D" id="BoxShape3D_pile"]
size = Vector3(1.8, 1.5, 1.3)

